ENVIRONMENT=development

# LLM via OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-235b-a22b

# HubSpot
# Prefer setting a Private App access token (starts with `pat-...`).
HUBSPOT_ACCESS_TOKEN=pat-...
# Back-compat fallbacks (if you don't use HUBSPOT_ACCESS_TOKEN).
HUBSPOT_DEVELOPER_API_KEY=
HUBSPOT_PERSONAL_ACCESS_KEY=
HUBSPOT_BASE_URL=https://api.hubapi.com

# Cal.com self-hosted
# Local-only: use http://localhost:3000 here and in calcom/.env.
# Public tunnel: if you expose Cal.com with ngrok or Cloudflare Tunnel,
# set the same public base URL here and in calcom/.env for NEXT_PUBLIC_WEBAPP_URL
# and NEXTAUTH_URL.
CALCOM_API_KEY=cal_...
CALCOM_BASE_URL=http://localhost:3000
CALCOM_EVENT_TYPE_ID=1

# Langfuse cloud
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Resend (outbound email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=outreach@yourdomain.com

# Outbound safety (defaults to sink mode)
# OUTBOUND_ENABLED must be explicitly set true for live sends.
OUTBOUND_ENABLED=false
OUTBOUND_SINK_EMAIL=sink@tenacious.example
OUTBOUND_SINK_PHONE=+15555550123

# Africa's Talking (SMS)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=...
AFRICASTALKING_SHORT_CODE=...

# Local data files — download once, never commit
CRUNCHBASE_ODM_PATH=./data/crunchbase_odm_sample.json
LAYOFFS_FYI_PATH=./data/layoffs_fyi.csv
SMS_SUPPRESSION_PATH=./data/sms_suppression.json
BENCH_SUMMARY_PATH=./data/bench_summary.json
